<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:weightSum="10">

    <!-- Left Portion: Total Study Time Block (weight 3.5) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3.5"
        android:orientation="vertical"
        android:gravity="start|center_vertical"
        android:paddingEnd="6dp">

        <TextView
            android:id="@+id/widget_title_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="আজকের পড়াশোনা"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <!-- Total Time Segmented layout -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_hours_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_hours_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ঘ"
                android:textColor="#38BDF8"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="6dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_mins_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_mins_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="মি"
                android:textColor="#38BDF8"
                android:textSize="14sp"
                android:layout_marginStart="2dp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Right Portion: Progress Bar and List (weight 6.5) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="6.5"
        android:orientation="vertical"
        android:paddingStart="6dp">

        <!-- Custom Segmented Progress Bar Image -->
        <ImageView
            android:id="@+id/widget_progress_bar"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginBottom="6dp"
            android:scaleType="fitXY"
            android:contentDescription="Progress bar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">
            
            <!-- Row 1 -->
            <LinearLayout
                android:id="@+id/widget_row1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start"
                android:layout_marginEnd="4dp">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/widget_row1_bullet"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:src="@drawable/widget_bullet"
                        android:contentDescription="bullet" />
                    <TextView
                        android:id="@+id/widget_row1_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="জীববিজ্ঞান"
                        android:textColor="#E2E8F0"
                        android:textSize="10sp"
                        android:singleLine="true"
                        android:ellipsize="end" />
                </LinearLayout>
                <TextView
                    android:id="@+id/widget_row1_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 মি"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:id="@+id/widget_row2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start"
                android:layout_marginEnd="4dp">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/widget_row2_bullet"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:src="@drawable/widget_bullet"
                        android:contentDescription="bullet" />
                    <TextView
                        android:id="@+id/widget_row2_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="রসায়ন"
                        android:textColor="#E2E8F0"
                        android:textSize="10sp"
                        android:singleLine="true"
                        android:ellipsize="end" />
                </LinearLayout>
                <TextView
                    android:id="@+id/widget_row2_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 মি"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout
                android:id="@+id/widget_row3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/widget_row3_bullet"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:src="@drawable/widget_bullet"
                        android:contentDescription="bullet" />
                    <TextView
                        android:id="@+id/widget_row3_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="পদার্থবিজ্ঞান"
                        android:textColor="#E2E8F0"
                        android:textSize="10sp"
                        android:singleLine="true"
                        android:ellipsize="end" />
                </LinearLayout>
                <TextView
                    android:id="@+id/widget_row3_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 মি"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Timestamp (Refresh marker) -->
        <TextView
            android:id="@+id/widget_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="02/06, 3:08 pm ↻"
            android:textColor="#94A3B8"
            android:textSize="8sp" />

    </LinearLayout>
</LinearLayout>
